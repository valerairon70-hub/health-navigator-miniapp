# Токен Telegram бота — получить у @BotFather командой /mybots → выбрать бота → API Token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Gemini API Key (зарезервировано на будущее, сейчас не используется)
GEMINI_API_KEY=your_gemini_api_key_here

# URL приложения (для локальной разработки — localhost, для продакшна — Vercel URL)
APP_URL=http://localhost:3000
